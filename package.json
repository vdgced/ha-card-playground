{
  "name": "ha-card-playground",
  "version": "0.7.91",
  "description": "Home Assistant Card Playground — Live card preview with detachable window · by VDG7",
  "author": "VDG7",
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "watch": "rollup -c rollup.config.js --watch",
    "serve": "node serve.mjs",
    "release:patch": "npm version patch && npm run build",
    "release:minor": "npm version minor && npm run build",
    "use:dev": "node switch-mode.mjs dev",
    "use:prod": "node switch-mode.mjs prod"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.28.0",
    "lit": "^3.1.4",
    "yaml": "^2.8.3"
  }
}
